# PostgreSQL connection string (required for Prisma).
# Add connection_limit and pool_timeout to avoid P2024 "Timed out fetching a new connection" errors
# when many requests run at once (e.g. order page + admin). Example:
# DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_self_order?schema=public&connection_limit=20&pool_timeout=30"
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_self_order?schema=public&connection_limit=20&pool_timeout=30"
